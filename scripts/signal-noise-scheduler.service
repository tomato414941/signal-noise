[Unit]
Description=signal-noise Scheduler
After=network.target

[Service]
Type=simple
User=dev
WorkingDirectory=/home/dev/projects/signal-noise
ExecStart=/home/dev/projects/signal-noise/.venv/bin/python -m signal_noise scheduler
Restart=always
RestartSec=15
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
